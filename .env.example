# =============================================================
# TICKETON BACKEND — Variáveis de ambiente
# Copie para .env e ajuste conforme necessário
# =============================================================

# ── Servidor ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Banco de Dados ───────────────────────────────────────────
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USERNAME=ticketon
DATABASE_PASSWORD=password
DATABASE_NAME=ticketon

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=mude_esta_chave_em_producao_2025
JWT_EXPIRES_IN=1d

# ── Mercado Pago ─────────────────────────────────────────────
# Obtenha sua chave em: https://www.mercadopago.com.br/developers
# Use a chave TEST-... para sandbox (desenvolvimento)
MP_ACCESS_TOKEN=TEST-SEU_ACCESS_TOKEN_AQUI

# ── URLs ─────────────────────────────────────────────────────
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001
